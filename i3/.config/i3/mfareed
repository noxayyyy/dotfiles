# exec_always --no-startup-id xrandr --output HDMI-A-0 --rotate left --auto --left-of eDP &

workspace 1 output DP-1-1
workspace 2 output HDMI-A-0
workspace 3 output eDP

# swap escape and caps lock
exec_always --no-startup-id setxkbmap -option caps:swapescape
# configure touchpad to detect taps
exec_always --no-startup-id "$HOME/.config/i3/touchpad.sh"
exec_always --no-startup-id "$HOME/.config/i3/tkl_kbd_conf.sh"
# allow bluetoothctl commands
exec_always --no-startup-id rfkill unblock bluetooth
# exec_always --no-startup-id xinput set-prop 21 335 1
# run compositor
exec_always --no-startup-id xcompmgr -c

# run polybar
exec_always --no-startup-id "$HOME/.config/polybar/shapes/launch.sh"
